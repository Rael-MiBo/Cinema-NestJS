generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model Genero {
  id     Int     @id @default(autoincrement())
  nome   String  @unique
  filmes Filme[]
}

model Filme {
  id                  Int      @id @default(autoincrement())
  titulo              String
  duracao             Int
  classificacaoEtaria String
  generoId            Int
  genero              Genero   @relation(fields: [generoId], references: [id])
  sessoes             Sessao[]
}

model Sala {
  id         Int      @id @default(autoincrement())
  numero     String   @unique
  capacidade Int
  sessoes    Sessao[]
}

model Sessao {
  id             Int        @id @default(autoincrement())
  data           DateTime
  valorIngresso  Float
  filmeId        Int
  salaId         Int
  filme          Filme      @relation(fields: [filmeId], references: [id])
  sala           Sala       @relation(fields: [salaId], references: [id])
  ingressos      Ingresso[]
}

model Ingresso {
  id         Int     @id @default(autoincrement())
  tipo       String
  valorPago  Float
  sessaoId   Int
  sessao     Sessao  @relation(fields: [sessaoId], references: [id])
  pedidoId   Int?
  pedido     Pedido? @relation(fields: [pedidoId], references: [id])
}

model LancheCombo {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  itens     String?
  pedidos   Pedido[]
}

model Pedido {
  id         Int           @id @default(autoincrement())
  valorTotal Float         @default(0)
  dataHora   DateTime      @default(now())
  ingressos  Ingresso[]
  lanches    LancheCombo[]
}