generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model Genero {
  id     Int     @id @default(autoincrement())
  nome   String  @unique
  filmes Filme[]
}

model Filme {
  id                 Int      @id @default(autoincrement())
  titulo             String
  sinopse            String?
  classificacao      String
  duracao            Int
  elenco             String?
  dataIniciaExibicao DateTime
  dataFinalExibicao  DateTime
  generoId           Int
  genero             Genero   @relation(fields: [generoId], references: [id])
  sessoes            Sessao[]
}

model Sala {
  id         Int      @id @default(autoincrement())
  numero     String
  capacidade Int
  poltronas  Json     @default("[]")
  sessoes    Sessao[]
}

model Sessao {
  id             Int        @id @default(autoincrement())
  data           DateTime
  valorIngresso  Float
  filmeId        Int
  salaId         Int
  filme          Filme      @relation(fields: [filmeId], references: [id])
  sala           Sala       @relation(fields: [salaId], references: [id])
  ingressos      Ingresso[]
}

model Ingresso {
  id         Int      @id @default(autoincrement())
  tipo       String
  valorPago  Float
  sessaoId   Int
  sessao     Sessao   @relation(fields: [sessaoId], references: [id])
  pedidoId   Int?
  pedido     Pedido?  @relation(fields: [pedidoId], references: [id])
  fila       Int      @default(0)
  assento    Int      @default(0)
}

model LancheCombo {
  id            Int                @id @default(autoincrement())
  nome          String
  descricao     String?
  valorUnitario Float              @default(0)
  qtUnidade     Int                @default(0)
  subtotal      Float              @default(0)
  pedidos       ItemPedidoLanche[]
}

model Pedido {
  id         Int                @id @default(autoincrement())
  dataHora   DateTime           @default(now())
  valorTotal Float
  qtInteira  Int                @default(0)
  qtMeia     Int                @default(0)
  ingressos  Ingresso[]
  lanches    ItemPedidoLanche[]
}

model ItemPedidoLanche {
  id         Int         @id @default(autoincrement())
  quantidade Int         @default(1)
  pedidoId   Int
  pedido     Pedido      @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  lancheId   Int
  lanche     LancheCombo @relation(fields: [lancheId], references: [id])
}